# Copy this file to .env and fill in real values.

# --- Postgres connection ---
# Either set DATABASE_URL directly:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio_wiki
# ...or leave DATABASE_URL unset and use these instead:
PGUSER=postgres
PGPASSWORD=postgres
PGHOST=localhost
PGPORT=5432
PGDATABASE=portfolio_wiki

# --- Admin panel ---
# The password you type into /admin to log in. Change this.
ADMIN_PASSWORD=change-this-password
# Used to sign the admin session token. Change this to a long random string.
JWT_SECRET=change-this-to-a-long-random-string

# --- Server ---
PORT=5000
# Comma-separated list of origins allowed to call this API
CORS_ORIGIN=http://localhost:3000
